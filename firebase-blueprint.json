{
  "entities": {
    "HistoryItem": {
      "title": "History Item",
      "description": "An image generated by the user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "prompt": { "type": "string" },
        "timestamp": { "type": "number" },
        "userId": { "type": "string" }
      },
      "required": ["id", "url", "prompt", "timestamp", "userId"]
    },
    "PromptCategory": {
      "title": "Prompt Category",
      "description": "A category containing multiple prompts",
      "type": "object",
      "properties": {
        "category": { "type": "string" },
        "prompts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "prompt": { "type": "string" }
            },
            "required": ["title", "prompt"]
          }
        },
        "userId": { "type": "string" }
      },
      "required": ["category", "prompts", "userId"]
    }
  },
  "firestore": {
    "/users/{userId}/history/{historyId}": {
      "schema": { "$ref": "#/entities/HistoryItem" },
      "description": "User's generated image history"
    },
    "/users/{userId}/promptBank/{categoryId}": {
      "schema": { "$ref": "#/entities/PromptCategory" },
      "description": "User's custom prompt bank categories"
    }
  }
}
